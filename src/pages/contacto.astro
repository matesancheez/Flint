---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const subjects = [
  "Meeting Agenda",
  "Project Update",
  "Action Items",
  "New Hire Onboarding",
  "Budget Review",
  "Marketing Strategy",
  "Quarterly Report",
];
---

<Layout title="Flint - Ponte en contacto con nosotros">
  <Navbar />
  <div
    class="w-[80%] lg:w-[35%] bg-zinc-500/75 backdrop-blur-lg mx-auto p-8 mt-10 rounded-lg"
  >
    <form
      autocomplete="off"
      action="https://formspree.io/f/xleyabzv"
      method="POST"
    >
      <div class="mb-5">
        <label for="name" class="mb-3 block text-base font-medium text-[#000]">
          Full Name
        </label>
        <input
          required
          type="text"
          name="name"
          id="name"
          placeholder="Full Name"
          class="w-full rounded-md border border-[#e0e0e0] bg-white py-3 px-6 text-base font-medium text-[#6B7280] outline-none focus:border-[#6A64F1] focus:shadow-md"
        />
      </div>
      <div class="mb-5">
        <label for="email" class="mb-3 block text-base font-medium text-[#000]">
          Email Address
        </label>
        <input
          required
          type="email"
          name="email"
          id="email"
          placeholder="example@domain.com"
          class="w-full rounded-md border border-[#e0e0e0] bg-white py-3 px-6 text-base font-medium text-[#6B7280] outline-none focus:border-[#6A64F1] focus:shadow-md"
        />
      </div>
      <div class="mb-5">
        <label
          for="subject"
          class="mb-3 block text-base font-medium text-[#000]"
          >Selecciona un subject:</label
        >
        <select
          required
          id="subject"
          name="subject"
          class="w-full text-gray-400 rounded-md border border-[#e0e0e0] bg-white py-3 px-6 text-base font-medium"
        >
          <option value="default" selected class="text-black"
            >Selecciona un subject</option
          >
          {
            subjects.map((subject) => (
              <option value={subject} class="text-black">
                {subject}
              </option>
            ))
          }
        </select>
      </div>
      <div class="mb-5">
        <label
          for="message"
          class="mb-3 block text-base font-medium text-[#000]"
        >
          Message
        </label>
        <textarea
          required
          rows="4"
          name="message"
          id="message"
          placeholder="Type your message"
          class="w-full resize-none rounded-md border border-[#e0e0e0] bg-white py-3 px-6 text-base font-medium text-[#6B7280] outline-none focus:border-[#6A64F1] focus:shadow-md"
        ></textarea>
      </div>
      <div class="text-center">
        <button
          type="submit"
          class="inline-flex items-center justify-center px-4 py-2 text-base
          font-bold leading-6 text-black bg-[#dec998]/75 ease-in duration-200 border border-transparent rounded-md
          hover:bg-zinc-800/75 hover:text-white focus:outline-none focus:ring-2 focus:ring-offset-2
          focus:bg-zinc-800/75"
        >
          Submit
        </button>
      </div>
    </form>
  </div>
  <Footer />
</Layout>
