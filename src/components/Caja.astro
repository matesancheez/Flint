---
const servicio = Astro.props;
---

<div
  class="text-black p-3 bg-[#dec998]/75 rounded-xl w-full h-auto text-center md:text-left ease-in duration-200 hover:bg-[#dec998]/100 backdrop-blur-md"
>
  <div class="flex justify-center md:justify-between items-center pb-3">
    <h1 class="font-bold text-lg lg:text-xl md:block hidden">
      {servicio.servicio.name}
    </h1>
    <img
      src={servicio.servicio.icon}
      alt={servicio.servicio.name}
      width="50"
      height="50"
    />
  </div>
  <div>
    <h1 class="font-semibold text-sm lg:text-xl block md:hidden">
      {servicio.servicio.name}
    </h1>
    <p class="hidden md:block text-lg">
      {servicio.servicio.description}
    </p>
  </div>
</div>
