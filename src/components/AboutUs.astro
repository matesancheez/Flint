---
import Mision from "../components/iconos/Mision.astro";
import Vision from "../components/iconos/Vision2.astro";
---

<div>
  <div class="p-8 mt-20 flex justify-center">
    <h1 class="text-2xl md:text-center md:text-5xl lg:text-7xl uppercase">
      ¿quienes somos? <!--<b
        class="text-3xl uppercase block md:text-6xl lg:text-8xl gradient-text font-extrabold"
        >flint</b>-->
      <div class="flex justify-center">
        <img
          class="md:mx-auto p-2 lg:w-64"
          src="/FlintClaroSolo.avif"
          alt="Logo de flint marketing agency"
          width="100"
          height="100"
        />
      </div>
    </h1>
  </div>
  <div class="lg:px-36 px-12">
    <div>
      <div class="text-center">
        <h1 class="py-5 text-2xl font-bold">
          Te ayudamos a crecer mas rapido como negocio
        </h1>
        <p>
          Lorem ipsum dolor sit amet consectetur adipisicing elit. Cumque nihil
          facere architecto error quibusdam, non deserunt nobis quas culpa vel
          aut nisi fuga ipsam similique recusandae dolores aliquam molestiae
          omnis!
        </p>
      </div>

      <!--Tarjeta de mision y vision -->
      <div class="hidden md:grid md:gap-5 md:mt-24 lg:grid-cols-2">
        <div
          class="px-7 py-5 bg-zinc-500/75 rounded-xl w-full h-auto text-center md:text-left ease-in duration-200 hover:bg-zinc-700/100 backdrop-blur-md"
        >
          <div class="flex justify-center md:justify-between items-center pb-3">
            <h1 class="font-bold text-lg lg:text-3xl md:block hidden">
              Mision de la empresa
            </h1>
            <Mision />
          </div>
          <div>
            <p class="hidden md:block text-lg">
              Impulsar el éxito de nuestros clientes a través de estrategias de
              marketing digital innovadoras y personalizadas. Nos comprometemos
              a maximizar su visibilidad en línea
            </p>
          </div>
        </div>

        <div
          class="px-7 py-5 bg-zinc-500/75 rounded-xl w-full h-auto text-center md:text-left ease-in duration-200 hover:bg-zinc-700/100 backdrop-blur-md"
        >
          <div class="flex justify-center md:justify-between items-center pb-3">
            <h1 class="font-bold text-lg lg:text-3xl md:block hidden">
              Vison de Flint
            </h1>
            <Vision />
          </div>
          <div>
            <p class="hidden md:block text-lg">
              Ser reconocidos como líderes en el mercado argentino de marketing
              digital, destacándonos por nuestra creatividad, resultados
              excepcionales y el impacto positivo que generamos en la
              transformación digital de las empresas.
            </p>
          </div>
        </div>
      </div>
      <!--Tarjeta de mision y vision -->

      <div class="flex justify-center mt-10">
        <a
          href="#"
          class="inline-flex items-center justify-center px-8 py-4 text-base
                                    font-bold leading-6 text-black bg-[#dec998] ease-in duration-200 border border-transparent rounded-full
                                    hover:bg-[#dec998]/50 focus:outline-none focus:ring-2 focus:ring-[#000] focus:ring-offset-2"
        >
          Conocenos
        </a>
      </div>
    </div>
  </div>
</div>
